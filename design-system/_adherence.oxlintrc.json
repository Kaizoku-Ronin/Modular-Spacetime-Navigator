{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "ui_kits/simulator/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|JetBrains Mono|Space Grotesk))/i]",
        "message": "Font not provided by the design system. Available: Inter, JetBrains Mono, Space Grotesk."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|outline|pill|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, outline, pill, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:teal|warn|violet|alert|dim)$/]",
        "message": "<Badge> tone must be one of 'teal' | 'warn' | 'violet' | 'alert' | 'dim'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|variant|size|icon|pulse|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: tone, variant, size, icon, pulse, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:teal|warn|violet|alert)$/]",
        "message": "<Button> tone must be one of 'teal' | 'warn' | 'violet' | 'alert'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|ghost)$/]",
        "message": "<Button> variant must be one of 'solid' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|valueColor|divider|style|key|ref|className|style|children)$/]",
        "message": "<DataRow> doesn't accept that prop. Declared props: label, value, valueColor, divider, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='HudPanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|dot|dotColor|tag|tagTone|blur|children|style|key|ref|className|style|children)$/]",
        "message": "<HudPanel> doesn't accept that prop. Declared props: title, dot, dotColor, tag, tagTone, blur, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='HudPanel'] > JSXAttribute[name.name='tagTone'] > Literal[value!=/^(?:teal|warn|violet)$/]",
        "message": "<HudPanel> tagTone must be one of 'teal' | 'warn' | 'violet'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HudPanel'] > JSXAttribute[name.name='blur'] > Literal[value!=/^(?:hud|dock|panel)$/]",
        "message": "<HudPanel> blur must be one of 'hud' | 'dock' | 'panel'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModePill'] > JSXAttribute > JSXIdentifier[name!=/^(?:mode|style|key|ref|className|style|children)$/]",
        "message": "<ModePill> doesn't accept that prop. Declared props: mode, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModePill'] > JSXAttribute[name.name='mode'] > Literal[value!=/^(?:flight|starmap|jump)$/]",
        "message": "<ModePill> mode must be one of 'flight' | 'starmap' | 'jump'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slider'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|onChange|min|max|step|tone|displayValue|width|style|key|ref|className|style|children)$/]",
        "message": "<Slider> doesn't accept that prop. Declared props: label, value, onChange, min, max, step, tone, displayValue, width, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slider'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:teal|warn)$/]",
        "message": "<Slider> tone must be one of 'teal' | 'warn'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpectralBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|style|key|ref|className|style|children)$/]",
        "message": "<SpectralBadge> doesn't accept that prop. Declared props: type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusLine'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|text|style|key|ref|className|style|children)$/]",
        "message": "<StatusLine> doesn't accept that prop. Declared props: status, text, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusLine'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:cruising|paused|near-horizon)$/]",
        "message": "<StatusLine> status must be one of 'cruising' | 'paused' | 'near-horizon'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
